            "url": "{{base_url}}/api/notifications"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch(e) {}",
                  "const list = json?.data || [];",
                  "const unread = list.find(x => x && x.isRead === false);",
                  "if (unread?.id) pm.collectionVariables.set('notification_id', unread.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "User 2 Mark Notification Read",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{user2_token}}" }],
