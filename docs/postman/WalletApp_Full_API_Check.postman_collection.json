    {
      "name": "02 KYC Flow",
      "item": [
        {
          "name": "User 1 Submit KYC",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user1_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documentType\": \"passport\",\n  \"documentNumber\": \"P-USER1-1001\"\n}"
            },
            "url": "{{base_url}}/api/auth/kyc"
          }
        },
        {
          "name": "User 2 Submit KYC",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user2_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documentType\": \"driving_license\",\n  \"documentNumber\": \"DL-USER2-2002\"\n}"
            },
            "url": "{{base_url}}/api/auth/kyc"
          }
        },
        {
          "name": "Admin Get Pending KYC",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/api/admin/kyc/pending"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch(e) {}",
                  "const list = json?.data || [];",
                  "for (const item of list) {",
                  "  if (item?.email === pm.collectionVariables.get('user1_email')) pm.collectionVariables.set('user1_kyc_id', item.id);",
                  "  if (item?.email === pm.collectionVariables.get('user2_email')) pm.collectionVariables.set('user2_kyc_id', item.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Admin Approve User 1 KYC",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"Approved\",\n  \"adminNote\": \"Verified\"\n}"
            },
            "url": "{{base_url}}/api/admin/kyc/{{user1_kyc_id}}/decide"
          }
        },
        {
          "name": "Admin Approve User 2 KYC",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"Approved\",\n  \"adminNote\": \"Verified\"\n}"
            },
            "url": "{{base_url}}/api/admin/kyc/{{user2_kyc_id}}/decide"
          }
        }
      ]
    },
