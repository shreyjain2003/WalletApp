  "item": [
    {
      "name": "01 Auth - Register/Login",
      "item": [
        {
          "name": "Register User 1",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User One\",\n  \"email\": \"{{user1_email}}\",\n  \"phoneNumber\": \"9000000001\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch(e) {}",
                  "if (json?.data?.token) pm.collectionVariables.set('user1_token', json.data.token);",
                  "if (json?.data?.userId) pm.collectionVariables.set('user1_id', json.data.userId);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register User 2",
